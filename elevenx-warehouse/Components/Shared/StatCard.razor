<div class="stat-card @UiColors.CardTint(Color)">
    <div class="flex items-start justify-between gap-3">
        <span class="stat-label">@Label</span>
        <span class="stat-icon @UiColors.SoftBg(Color)"><Icon Name="@IconName" Class="w-5 h-5" /></span>
    </div>
    <div class="stat-value">@Value</div>
    @if (ChildContent is not null)
    {
        <div class="text-xs text-muted">@ChildContent</div>
    }
    else if (!string.IsNullOrEmpty(Sub))
    {
        <div class="text-xs text-muted">@Sub</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public string IconName { get; set; } = "box";
    [Parameter] public string Color { get; set; } = "accent";
    [Parameter] public string? Sub { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
