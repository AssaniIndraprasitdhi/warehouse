@page "/login"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject IJSRuntime JS

<PageTitle>เข้าสู่ระบบ • บ้านคลัง</PageTitle>

<div class="login-root" data-login-scene>

    <!-- ===== Aurora / drifting blobs (พื้นหลังเคลื่อนไหว) ===== -->
    <div class="login-aurora" aria-hidden="true">
        <span class="blob blob-1"></span>
        <span class="blob blob-2"></span>
        <span class="blob blob-3"></span>
        <span class="login-grid-overlay"></span>
    </div>

    <div class="relative z-10 grid min-h-screen lg:grid-cols-[1.08fr_0.92fr]">

        <!-- ===================== LEFT : 3D STAGE ===================== -->
        <section class="login-hero hidden lg:flex flex-col justify-between overflow-hidden p-12 xl:p-16 text-white">
            <!-- brand -->
            <div class="rise flex items-center gap-3">
                <span class="grid h-10 w-10 place-items-center rounded-xl bg-white/15 backdrop-blur ring-1 ring-white/25 text-white">@Logo("w-5 h-5")</span>
                <span class="text-lg font-semibold tracking-wide">บ้านคลัง</span>
            </div>

            <!-- 3D scene -->
            <div class="login-stage grid flex-1 place-items-center">
                <div class="login-scene">
                    <span class="orbit-ring orbit-ring--1"></span>
                    <span class="orbit-ring orbit-ring--2"></span>

                    <!-- rotating glass cube -->
                    <div class="cube-pos">
                        <div class="cube3d">
                            <div class="cube3d__f cube3d__f--front">บ้านคลัง</div>
                            <div class="cube3d__f cube3d__f--back">บ้านคลัง</div>
                            <div class="cube3d__f cube3d__f--right"></div>
                            <div class="cube3d__f cube3d__f--left"></div>
                            <div class="cube3d__f cube3d__f--top"></div>
                            <div class="cube3d__f cube3d__f--bottom"></div>
                        </div>
                    </div>

                    <!-- floating glass stat chips -->
                    <div class="float-chip float-chip--a">
                        <div class="text-[11px] text-white/70">สต็อกพร้อมใช้</div>
                        <div class="text-lg font-semibold leading-none mt-1">98.2%</div>
                        <div class="chip-bar"><span style="width:92%"></span></div>
                    </div>
                    <div class="float-chip float-chip--b">
                        <div class="flex items-center gap-2">
                            <span class="grid h-7 w-7 place-items-center rounded-lg bg-white/20 text-[13px]">฿</span>
                            <div>
                                <div class="text-[11px] text-white/70">ค่าใช้จ่ายเดือนนี้</div>
                                <div class="text-sm font-semibold leading-none mt-0.5">▼ 12%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- headline + features -->
            <div class="rise" style="animation-delay:.12s">
                <h2 class="text-3xl xl:text-[2.6rem] font-semibold leading-[1.15]">
                    จัดการคลัง &amp; ค่าใช้จ่าย<br />ครบ จบ ในที่เดียว
                </h2>
                <ul class="mt-7 space-y-3 text-sm text-white/85">
                    <li class="flex items-center gap-3">
                        <span class="feat-tick">@CheckSvg</span> ติดตามสต็อก IoT / Server / Software แบบเรียลไทม์
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="feat-tick">@CheckSvg</span> คุมค่าใช้จ่าย การซื้อ และการเบิกของในที่เดียว
                    </li>
                    <li class="flex items-center gap-3">
                        <span class="feat-tick">@CheckSvg</span> แจ้งเตือน License &amp; Subscription ใกล้ครบรอบ
                    </li>
                </ul>
            </div>
        </section>

        <!-- ===================== RIGHT : FORM ===================== -->
        <section class="flex items-center justify-center p-6 sm:p-10">
            <div class="login-card rise w-full max-w-md">

                <!-- brand (มือถือ) -->
                <div class="mb-7 flex flex-col items-center text-center lg:hidden">
                    <span class="mb-3 grid h-14 w-14 place-items-center rounded-2xl bg-accent text-white shadow-lg shadow-accent/30">@Logo("w-7 h-7")</span>
                    <h2 class="text-xl font-semibold text-text">บ้านคลัง</h2>
                </div>

                <div class="pop text-center">
                    <h1 class="text-2xl font-semibold text-text">ยินดีต้อนรับกลับ</h1>
                    <p class="mt-1.5 text-sm text-muted">เข้าสู่ระบบเพื่อจัดการคลังของคุณ</p>
                </div>

                @if (!string.IsNullOrEmpty(Error))
                {
                    <div class="mt-5">
                        <AlertBanner Type="danger" Message="@ErrorMessage" />
                    </div>
                }

                <form method="post" action="/auth/login" class="mt-6 space-y-4"
                      onsubmit="document.getElementById('login-btn').disabled=true; document.getElementById('login-spin').classList.remove('hidden'); document.getElementById('login-text').classList.add('hidden');">
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />

                    <!-- email -->
                    <div class="pop">
                        <label class="form-label" for="email">อีเมล</label>
                        <div class="field-wrap">
                            <span class="field-icon">@MailSvg</span>
                            <input id="email" name="email" type="email" required autofocus autocomplete="username"
                                   class="input field-input" placeholder="name@elevenx.local" value="@PrefillEmail" />
                        </div>
                    </div>

                    <!-- password -->
                    <div class="pop">
                        <label class="form-label" for="password">รหัสผ่าน</label>
                        <div class="field-wrap">
                            <span class="field-icon">@LockSvg</span>
                            <input id="password" name="password" type="password" required autocomplete="current-password"
                                   class="input field-input field-input--pw" placeholder="••••••••" />
                            <button type="button" class="field-eye" tabindex="-1" title="แสดง/ซ่อนรหัสผ่าน"
                                    onclick="window.elevenx.togglePw(this)">
                                <span data-eye-on>@EyeSvg</span>
                                <span data-eye-off class="hidden">@EyeOffSvg</span>
                            </button>
                        </div>
                    </div>

                    <button id="login-btn" type="submit" class="login-submit mt-1">
                        <span id="login-spin" class="spinner spinner-light hidden"></span>
                        <span id="login-text" class="inline-flex items-center gap-2">
                            เข้าสู่ระบบ @ArrowSvg
                        </span>
                    </button>
                </form>

                <p class="mt-6 text-center text-xs text-muted">© @DateTime.Now.Year บ้านคลัง</p>
            </div>
        </section>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private string PrefillEmail => "";

    private string ErrorMessage => Error switch
    {
        "locked" => "บัญชีถูกล็อก กรุณาติดต่อผู้ดูแลระบบ",
        _ => "อีเมลหรือรหัสผ่านไม่ถูกต้อง",
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("elevenx.initLoginScene");
    }

    // ===== inline SVG (ควบคุม stroke/ขนาดเองได้เต็มที่) =====
    private const string Stroke = "fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"";
    private MarkupString MailSvg => new($"<svg viewBox=\"0 0 24 24\" {Stroke}><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"/><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"/></svg>");
    private MarkupString LockSvg => new($"<svg viewBox=\"0 0 24 24\" {Stroke}><rect width=\"18\" height=\"11\" x=\"3\" y=\"11\" rx=\"2\"/><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"/></svg>");
    private MarkupString EyeSvg => new($"<svg viewBox=\"0 0 24 24\" {Stroke}><path d=\"M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z\"/><circle cx=\"12\" cy=\"12\" r=\"3\"/></svg>");
    private MarkupString EyeOffSvg => new($"<svg viewBox=\"0 0 24 24\" {Stroke}><path d=\"M9.88 9.88a3 3 0 1 0 4.24 4.24\"/><path d=\"M10.73 5.08A10.4 10.4 0 0 1 12 5c7 0 10 7 10 7a13.2 13.2 0 0 1-1.67 2.68\"/><path d=\"M6.61 6.61A13.5 13.5 0 0 0 2 12s3 7 10 7a9.7 9.7 0 0 0 5.39-1.61\"/><path d=\"m2 2 20 20\"/></svg>");
    private MarkupString ArrowSvg => new($"<svg viewBox=\"0 0 24 24\" {Stroke} class=\"h-[18px] w-[18px] login-arrow\"><path d=\"M5 12h14\"/><path d=\"m12 5 7 7-7 7\"/></svg>");
    private MarkupString CheckSvg => new($"<svg viewBox=\"0 0 24 24\" {Stroke} class=\"h-3.5 w-3.5\"><path d=\"M20 6 9 17l-5-5\"/></svg>");
    // โลโก้มาร์ก: ไอคอนลูกบาศก์ (echo ฉาก 3D) แทนตัวย่อ
    private MarkupString Logo(string cls) => new($"<svg viewBox=\"0 0 24 24\" {Stroke} class=\"{cls}\"><path d=\"M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z\"/><path d=\"m3.3 7 8.7 5 8.7-5\"/><path d=\"M12 22V12\"/></svg>");
}
